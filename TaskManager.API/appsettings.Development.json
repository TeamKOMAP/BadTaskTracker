{
  "Database": {
    "Provider": "Sqlite"
  },
  "Jwt": {
    "Issuer": "GoodTaskTracker",
    "Audience": "GoodTaskTracker.Client",
    "SigningKey": "CHANGE_ME_IN_PRODUCTION_WITH_32_PLUS_CHARS",
    "AccessTokenLifetimeMinutes": 60
  },
  "Email": {
    "Provider": "Smtp",
    "HttpApi": {
      "Provider": "Resend",
      "BaseUrl": "https://api.resend.com",
      "SendPath": "/emails",
      "ApiKey": "",
      "FromEmail": "",
      "FromName": "BadTaskTracker",
      "TimeoutSeconds": 10
    }
  },
  "EmailAuth": {
    "CodeLength": 6,
    "CodeLifetimeMinutes": 10,
    "ResendCooldownSeconds": 60,
    "MaxAttempts": 5,
    "SenderName": "GoodTaskTracker",
    "EnableDevelopmentCodeFallback": false,
    "ExposeDevelopmentCodeInResponse": false
  },
  "Smtp": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "EnableSsl": true,
    "Username": "",
    "Password": "",
    "FromEmail": "",
    "FromName": "GoodTaskTracker",
    "TimeoutSeconds": 10
  },
  "Profile": {
    "NicknameChangeCooldownHours": 3
  },
  "Storage": {
    "Provider": "Local",
    "PublicBucket": "gtt-public",
    "PrivateBucket": "gtt-private",
    "Endpoint": "http://localhost:9000",
    "Region": "us-east-1",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin",
    "ForcePathStyle": true,
    "PostgresConnectionString": "",
    "PostgresSchema": "public",
    "PostgresTable": "object_storage_items",
    "LocalRootPath": "App_Data/object-storage"
  },
  "DatabaseStartup": {
    "MigrateLegacyFiles": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
