{
  "Database": {
    "Provider": "Postgres"
  },
  "Chat": {
    "Enabled": false,
    "MaxMessageLength": 4000,
    "MaxAttachmentsPerMessage": 5
  },
  "ChatEncryption": {
    "Enabled": false,
    "Algorithm": "AES-GCM",
    "KeyId": ""
  },
  "ChatRateLimit": {
    "MessagesPerMinutePerUser": 30,
    "MessagesPerMinutePerWorkspace": 300,
    "Burst": 10
  },
  "DatabaseStartup": {
    "ApplyMigrations": true,
    "Seed": false,
    "MigrateLegacyFiles": false,
    "SmokeCheckConnection": true,
    "FailFast": true
  }
}
