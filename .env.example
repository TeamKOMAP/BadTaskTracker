# Runtime
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_FORWARDEDHEADERS_ENABLED=true

# Database provider: Sqlite or Postgres
# Development default: Sqlite
# Production default (appsettings.Production.json): Postgres
Database__Provider=Sqlite
# SQLite example (Render production): Data Source=/var/data/TaskManager.db
ConnectionStrings__DefaultConnection=Data Source=TaskManager.db
# PostgreSQL example: Host=localhost;Port=5432;Database=taskmanager;Username=postgres;Password=postgres
ConnectionStrings__Postgres=

# JWT
Jwt__Issuer=GoodTaskTracker
Jwt__Audience=GoodTaskTracker.Client
Jwt__SigningKey=CHANGE_ME_IN_PRODUCTION_WITH_32_PLUS_CHARS
Jwt__AccessTokenLifetimeMinutes=60

# Email transport
# Provider: Smtp or HttpApi
Email__Provider=HttpApi

# HTTP email API (Resend-compatible)
Email__HttpApi__Provider=Resend
Email__HttpApi__BaseUrl=https://api.resend.com
Email__HttpApi__SendPath=/emails
Email__HttpApi__ApiKey=your-http-email-api-key
Email__HttpApi__FromEmail=your-verified-sender@example.com
Email__HttpApi__FromName=BadTaskTracker
Email__HttpApi__TimeoutSeconds=10

# SMTP fallback (optional)
Smtp__Username=your-smtp-username
Smtp__Password=your-smtp-password
Smtp__FromEmail=your-from-email
Smtp__Host=smtp.gmail.com
Smtp__Port=587
Smtp__EnableSsl=true
Smtp__FromName=GoodTaskTracker
Smtp__TimeoutSeconds=10

# Profile settings
Profile__NicknameChangeCooldownHours=3

# Chat settings
Chat__Enabled=false
Chat__MaxMessageLength=4000
Chat__MaxAttachmentsPerMessage=5

# Chat encryption settings
ChatEncryption__Enabled=false
ChatEncryption__Algorithm=AES-GCM
ChatEncryption__KeyId=

# Chat rate limit settings
ChatRateLimit__MessagesPerMinutePerUser=30
ChatRateLimit__MessagesPerMinutePerWorkspace=300
ChatRateLimit__Burst=10

# Storage settings
# Local example: Storage__Provider=Local
# MinIO/S3 example: Storage__Provider=S3 and set Endpoint/AccessKey/SecretKey
# PostgreSQL object storage example: Storage__Provider=Postgres
Storage__Provider=Local
Storage__PublicBucket=gtt-public
Storage__PrivateBucket=gtt-private
Storage__Endpoint=
Storage__Region=us-east-1
Storage__AccessKey=
Storage__SecretKey=
Storage__ForcePathStyle=true
Storage__PostgresConnectionString=
Storage__PostgresSchema=public
Storage__PostgresTable=object_storage_items
Storage__LocalRootPath=App_Data/object-storage

# Startup behavior
DatabaseStartup__ApplyMigrations=true
DatabaseStartup__Seed=false
DatabaseStartup__MigrateLegacyFiles=false
